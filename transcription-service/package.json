{
  "name": "transcription-service",
  "version": "1.0.0",
  "description": "Real-time audio transcription microservice using Google Cloud Speech-to-Text",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "watch": "nodemon --exec ts-node src/server.ts"
  },
  "dependencies": {
    "@google-cloud/speech": "^6.0.1",
    "dotenv": "^16.3.1",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/node": "^20.8.0",
    "@types/ws": "^8.5.8",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  },
  "keywords": [
    "transcription",
    "websocket",
    "google-cloud",
    "speech-to-text"
  ],
  "author": "Aviniti",
  "license": "MIT"
}
